generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
  SITE_MANAGER
}

enum ProjectStatus {
  ACTIVE
  ON_TRACK
  NEEDS_ATTENTION
  DELAYED
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  DONE
}

enum VariationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TradieScheduleStatus {
  PENDING
  PENDING_RESPONSE
  CONFIRMED
  NO_RESPONSE
  DECLINED
  COMPLETED
}

enum MaterialStatus {
  PENDING
  ORDERED
  DELIVERED
  INSTALLED
}

model Project {
  id               String   @id @default(uuid())
  name             String
  description      String?
  buildingType     String   @default("Double Storey 4BR + Study")
  lotSize          Decimal? @db.Decimal(10, 2)
  council          String   @default("Sydney City Council")
  customerId       String
  location         String
  siteManagerId    String?
  totalBudget      Decimal  @db.Decimal(12, 2)
  spent            Decimal  @default(0) @db.Decimal(12, 2)
  startDate        DateTime
  estimatedEndDate DateTime
  requirements     Json?

  status    ProjectStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  customer        Customer         @relation("CustomerProjects", fields: [customerId], references: [id])
  siteManager     User?            @relation("SiteManagerProjects", fields: [siteManagerId], references: [id])
  milestones      Milestone[]
  siteUpdates     SiteUpdate[]
  variations      Variation[]
  tradieSchedules TradieSchedule[]
  files           File[]           @relation("ProjectFiles")
  activityLogs    ActivityLog[]
  materials       Material[]
  tradies         Tradie[]         @relation("ProjectTradies")

  @@index([name])
  @@index([customerId])
  @@index([siteManagerId])
  @@index([status])
}

model Milestone {
  id              String          @id @default(uuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  order           Int
  description     String?
  targetDate      DateTime
  startDate       DateTime?
  actualDate      DateTime?
  budget          Decimal         @default(10000) @db.Decimal(12, 2)
  spend           Decimal?        @db.Decimal(12, 2)
  status          MilestoneStatus @default(PENDING)
  isPhotoRequired Boolean         @default(false)
  parentId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteUpdates        SiteUpdate[]
  tradieSchedules    TradieSchedule[]
  activityLogs       ActivityLog[]
  files              File[]           @relation("MilestoneFiles")
  tradies            Tradie[]         @relation("TradieMilestones")
  parentMilestone    Milestone?       @relation("MilestoneHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  childrenMilestones Milestone[]      @relation("MilestoneHierarchy")

  @@unique([projectId, order])
  @@index([projectId])
  @@index([status])
}

model Material {
  id             String         @id @default(uuid())
  projectId      String
  name           String
  category       String
  specifications String?
  quantity       Int
  unitCost       Decimal        @db.Decimal(10, 2)
  totalCost      Decimal        @db.Decimal(12, 2)
  status         MaterialStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Tradie {
  id         String   @id @default(uuid())
  name       String
  company    String?
  trade      String
  tradeType  String
  phone      String   @unique
  email      String   @unique
  hourlyRate Decimal? @db.Decimal(8, 2)
  rating     Decimal? @db.Decimal(2, 1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projects   Project[]        @relation("ProjectTradies")
  milestones Milestone[]      @relation("TradieMilestones")
  schedules  TradieSchedule[]

  @@index([name])
  @@index([trade])
  @@index([tradeType])
  @@index([email])
  @@index([phone])
}

model File {
  id          String   @id @default(uuid())
  projectId   String
  milestoneId String?
  filename    String
  fileType    String
  filesize    Int
  url         String
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation("MilestoneFiles", fields: [milestoneId], references: [id], onDelete: Cascade)
  User      User       @relation("UserFiles", fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([uploadedBy])
}

model SiteUpdate {
  id          String   @id @default(uuid())
  projectId   String
  milestoneId String?
  authorId    String
  notes       String
  photoUrls   String[]

  createdAt DateTime @default(now())

  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([milestoneId])
}

model Variation {
  id            String          @id @default(uuid())
  projectId     String
  description   String
  cost          Decimal         @db.Decimal(10, 2)
  requestedDate DateTime        @default(now())
  approvedDate  DateTime?
  delayDays     Int             @default(0)
  status        VariationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model TradieSchedule {
  id             String               @id @default(uuid())
  tradieId       String
  projectId      String
  milestoneId    String?
  scheduledDate  DateTime
  durationDays   Int                  @default(1)
  status         TradieScheduleStatus @default(PENDING)
  reminderSentAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tradie    Tradie     @relation(fields: [tradieId], references: [id])
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([tradieId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([scheduledDate])
}

model ActivityLog {
  id          String  @id @default(uuid())
  projectId   String
  milestoneId String?
  authorId    String?
  type        String
  message     String

  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User?      @relation(fields: [authorId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([createdAt])
}

model Customer {
  id     String @id @default(uuid())
  userId String @unique
  name   String
  email  String @unique
  phone  String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[] @relation("CustomerProjects")
  user     User      @relation("CustomerUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  phone      String  @unique
  role       Role    @default(CUSTOMER)
  customerId String?
  clerkId    String  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files               File[]        @relation("UserFiles")
  customer            Customer?     @relation("CustomerUsers")
  siteManagerProjects Project[]     @relation("SiteManagerProjects")
  siteUpdates         SiteUpdate[]
  activityLogs        ActivityLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([clerkId])
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  WON
  LOST
  MEETING_SCHEDULED
  IN_FOLLOW_UP
  NO_RESPONSE
  CONVERTED
  CANCELLED
  DISQUALIFIED
}

enum HistoryType {
  SYSTEM
  CALL
  EMAIL
  REFERRAL
}

model Lead {
  id Int @id @default(autoincrement())

  name     String
  phone    String @default("")
  email    String @default("")
  location String @default("")

  source       String?
  sourceDetail String?

  stage LeadStage @default(NEW)

  assigned String?

  budget String?
  type   String[]

  notes String? @db.Text

  followupDate  DateTime?
  followupTime  String?
  followupNotes String?   @db.Text

  lostReason String?

  urgent Boolean @default(false)

  MicrosoftmessageId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history LeadHistory[]

  @@index([stage])
  @@index([assigned])
  @@index([createdAt])
}

model LeadHistory {
  id Int @id @default(autoincrement())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  action String
  detail String @db.Text

  type HistoryType

  actionDate DateTime

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
}
