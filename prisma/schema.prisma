generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  ADMIN
  CUSTOMER
  SITE_MANAGER
}

enum ProjectStatus {
  ACTIVE
  ON_TRACK
  NEEDS_ATTENTION
  DELAYED
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  DONE
}

enum VariationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TradieScheduleStatus {
  PENDING
  AWAITING_QUOTE
  PENDING_RESPONSE
  QUOTE_RECEIVED
  AWAITING_ADMIN_APPROVAL
  CONFIRMED
  NO_RESPONSE
  DECLINED
  COMPLETED
}

enum MaterialStatus {
  PENDING
  ORDERED
  DELIVERED
  INSTALLED
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  WON
  LOST
  MEETING_SCHEDULED
  IN_FOLLOW_UP
  NO_RESPONSE
  CONVERTED
  CANCELLED
  DISQUALIFIED
}

enum HistoryType {
  SYSTEM
  CALL
  EMAIL
  REFERRAL
}

enum AnnotationStatus {
  OPEN
  RESOLVED
}

enum OfferStatus {
  SENT
  PENDING
  ACCEPTED
  REJECTED
}

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TradieIncidentStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TradieApprovalActionType {
  PRICE_CHANGE
  INCIDENT_RESOLUTION
  TRADIE_REMOVAL
  SCHEDULE_APPROVAL
}

enum TradieApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Project {
  id               String   @id @default(uuid())
  leadId           Int      @unique
  name             String
  description      String?
  buildingType     String   @default("Double Storey 4BR + Study")
  lotSize          Decimal? @db.Decimal(10, 2)
  council          String   @default("Sydney City Council")
  customerId       String
  location         String
  siteManagerId    String?
  totalBudget      Decimal  @db.Decimal(12, 2)
  spent            Decimal  @default(0) @db.Decimal(12, 2)
  startDate        DateTime
  estimatedEndDate DateTime
  requirements     Json?

  status    ProjectStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  customer        Customer         @relation("CustomerProjects", fields: [customerId], references: [id])
  siteManager     User?            @relation("SiteManagerProjects", fields: [siteManagerId], references: [id])
  Lead            Lead             @relation("LeadProject", fields: [leadId], references: [id], onDelete: Cascade)
  milestones      Milestone[]
  siteUpdates     SiteUpdate[]
  variations      Variation[]
  tradieSchedules TradieSchedule[]
  files           File[]           @relation("ProjectFiles")
  activityLogs    ActivityLog[]
  materials       Material[]
  tradies         Tradie[]         @relation("ProjectTradies")

  @@index([name])
  @@index([customerId])
  @@index([siteManagerId])
  @@index([status])
}

model Milestone {
  id              String          @id @default(uuid())
  projectId       String
  invoiceId       String?
  name            String
  order           Int
  description     String?
  targetDate      DateTime
  startDate       DateTime?
  actualDate      DateTime?
  budget          Decimal         @default(10000) @db.Decimal(12, 2)
  spend           Decimal?        @db.Decimal(12, 2)
  status          MilestoneStatus @default(PENDING)
  isPhotoRequired Boolean         @default(false)
  parentId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteUpdates        SiteUpdate[]
  tradieSchedules    TradieSchedule[]
  activityLogs       ActivityLog[]
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files              File[]           @relation("MilestoneFiles")
  tradies            Tradie[]         @relation("TradieMilestones")
  parentMilestone    Milestone?       @relation("MilestoneHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  childrenMilestones Milestone[]      @relation("MilestoneHierarchy")

  @@unique([projectId, order])
  @@index([projectId])
  @@index([status])
}

model Material {
  id             String         @id @default(uuid())
  projectId      String
  name           String
  category       String
  specifications String?
  quantity       Int
  unitCost       Decimal        @db.Decimal(10, 2)
  totalCost      Decimal        @db.Decimal(12, 2)
  status         MaterialStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Tradie {
  id          String   @id @default(uuid())
  name        String
  trade       String
  abn         String   @unique
  phone       String   @unique
  email       String   @unique
  isFavourite Boolean  @default(false)
  hourlyRate  Decimal? @db.Decimal(8, 2)
  rating      Decimal? @db.Decimal(2, 1)
  note        String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects   Project[]        @relation("ProjectTradies")
  milestones Milestone[]      @relation("TradieMilestones")
  schedules  TradieSchedule[]
  incidents  TradieIncident[]
  approvals  TradieApproval[]
  ratings    TradieRating[]

  @@index([name])
  @@index([trade])
  @@index([email])
  @@index([phone])
}

model TradieIncident {
  id          String           @id @default(uuid())
  tradieId    String
  type        String
  severity    IncidentSeverity
  description String           @db.Text
  resolution  String?          @db.Text

  status TradieIncidentStatus @default(OPEN)

  createdAt DateTime @default(now())

  tradie Tradie @relation(fields: [tradieId], references: [id], onDelete: Cascade)
  files  File[] @relation("TradieIncidentFiles")

  @@index([tradieId])
  @@index([severity])
}

model TradieApproval {
  id           String                   @id @default(uuid())
  tradieId     String
  actionType   TradieApprovalActionType
  status       TradieApprovalStatus     @default(PENDING)
  reason       String                   @db.Text
  updationData Json?
  requestedBy  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tradie Tradie @relation(fields: [tradieId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([tradieId])
  @@index([requestedBy])
}

model TradieRating {
  id       String  @id @default(uuid())
  tradieId String
  userId   String
  rating   Decimal @db.Decimal(2, 1)
  comment  String? @db.Text

  createdAt DateTime @default(now())

  tradie Tradie @relation(fields: [tradieId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tradieId])
  @@index([userId])
}

model File {
  id          String   @id @default(uuid())
  projectId   String?
  milestoneId String?
  leadId      Int?
  incidentId  String?
  filename    String
  fileType    String
  filesize    Int
  url         String
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project?        @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone?      @relation("MilestoneFiles", fields: [milestoneId], references: [id], onDelete: Cascade)
  lead      Lead?           @relation("LeadFiles", fields: [leadId], references: [id], onDelete: Cascade)
  incident  TradieIncident? @relation("TradieIncidentFiles", fields: [incidentId], references: [id], onDelete: Cascade)
  User      User            @relation("UserFiles", fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([incidentId])
  @@index([leadId])
  @@index([uploadedBy])
}

model SiteUpdate {
  id          String   @id @default(uuid())
  projectId   String
  milestoneId String?
  authorId    String
  notes       String
  photoUrls   String[]

  createdAt DateTime @default(now())

  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([milestoneId])
}

model Variation {
  id            String          @id @default(uuid())
  projectId     String
  description   String
  cost          Decimal         @db.Decimal(10, 2)
  requestedDate DateTime        @default(now())
  approvedDate  DateTime?
  delayDays     Int             @default(0)
  status        VariationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model TradieSchedule {
  id             String               @id @default(uuid())
  tradieId       String
  projectId      String
  milestoneId    String?
  scheduledDate  DateTime
  durationDays   Int                  @default(1)
  requiresQuote  Boolean              @default(false)
  quotedPrice    String?
  status         TradieScheduleStatus @default(PENDING)
  reminderSentAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tradie    Tradie     @relation(fields: [tradieId], references: [id])
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([tradieId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([scheduledDate])
}

model ActivityLog {
  id          String  @id @default(uuid())
  projectId   String
  milestoneId String?
  authorId    String?
  type        String
  message     String

  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User?      @relation(fields: [authorId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([createdAt])
}

model Customer {
  id    String @id @default(uuid())
  name  String
  email String @unique
  phone String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[] @relation("CustomerProjects")

  @@index([email])
  @@index([phone])
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  phone      String  @unique
  role       Role    @default(CUSTOMER)
  customerId String?
  clerkId    String  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files               File[]           @relation("UserFiles")
  siteManagerProjects Project[]        @relation("SiteManagerProjects")
  siteUpdates         SiteUpdate[]
  activityLogs        ActivityLog[]
  assignedLeads       Lead[]           @relation("LeadAssignee")
  reviews             TradieRating[]
  approvalRequests    TradieApproval[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([clerkId])
}

model Lead {
  id Int @id @default(autoincrement())

  name     String
  phone    String @default("")
  email    String @default("")
  location String @default("")

  source       String?
  sourceDetail String?

  stage     LeadStage  @default(NEW)
  runId     String?
  runStatus RunStatus?

  assignedId String? // <-- THE NEW FOREIGN KEY

  assigned String?

  budget String?
  type   String[]

  notes    String? @db.Text
  notesDoc Json?

  followupDate  DateTime?
  followupTime  String?
  followupNotes String?   @db.Text

  lostReason String?

  urgent Boolean @default(false)

  MicrosoftmessageId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers          Offer[]
  chatSessions    ChatSession[]
  history         LeadHistory[]
  noteAnnotations LeadNoteAnnotation[]
  files           File[]               @relation("LeadFiles")
  assignedUser    User?                @relation("LeadAssignee", fields: [assignedId], references: [id]) // <-- THE NEW RELATION
  project         Project?             @relation("LeadProject")

  @@index([stage])
  @@index([assignedId])
  @@index([createdAt])
}

model LeadNoteAnnotation {
  id String @id @default(uuid())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  selectedText     String           @db.Text
  comment          String           @db.Text
  mentionedUserIds String[]
  status           AnnotationStatus @default(OPEN)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([leadId])
  @@index([status])
}

model LeadHistory {
  id Int @id @default(autoincrement())

  leadId Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  action String
  detail String @db.Text

  type HistoryType

  actionDate DateTime

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
}

model Offer {
  id          String      @id @default(uuid())
  leadId      Int
  offerStatus OfferStatus @default(PENDING)

  amount      Decimal @db.Decimal(12, 2)
  gstAmount   Decimal @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  sentAt     DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerItems OfferItem[]
  offerFiles OfferFile[]
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId])
  @@index([leadId])
}

model OfferItem {
  id          String  @id @default(uuid())
  offerId     String
  item        String
  description String
  quantity    Int
  unit        String
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  version Int @default(1)

  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

model OfferFile {
  id        String   @id @default(uuid())
  offerId   String
  version   Int      @default(1)
  filename  String
  fileType  String
  filesize  Int
  url       String
  createdAt DateTime @default(now())

  offerContent Json

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, version])
  @@index([offerId])
}

model ChatSession {
  id     String @id @default(uuid())
  leadId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
  lead     Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model ChatMessage {
  id        String @id @default(uuid())
  sessionId String
  role      String
  content   Json

  timestamp DateTime @default(now())

  chatSession ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model EmailAdHock {
  id           String   @id @default(uuid())
  name         String
  emailSubject String
  htmlUrl      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_adhoc")
}
